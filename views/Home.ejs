<%- include('partials/header') %>

<main class="max-w-6xl mx-auto px-4 py-20">
  <div class="flex flex-col-reverse md:flex-row items-center justify-between min-h-[70vh] fade-in">
    <div class="text-center md:text-left mt-10 md:mt-0">
      <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-4">Hi, I'm Nikhil</h1>
      <p class="text-xl md:text-2xl text-gray-600 dark:text-gray-400">A coding enthusiast.</p>
    </div>
    <div class="w-48 h-48 md:w-72 md:h-72 rounded-full overflow-hidden shadow-2xl border-4 border-white dark:border-gray-800">
      <img src="/Profile.png" alt="Profile Image" class="w-full h-full object-cover" onerror="this.src='https://via.placeholder.com/300'">
    </div>
  </div>

  <div class="flex justify-center my-10 animate-bounce">
    <a href="#skills" class="p-2 rounded-full bg-blue-100 dark:bg-gray-800 text-blue-600 dark:text-blue-400">
      <span class="material-symbols-outlined">south</span>
    </a>
  </div>

  <section id="skills" class="py-20 fade-in">
    <h2 class="text-4xl font-bold mb-12 text-center">What I can do...</h2>
    <div class="grid md:grid-cols-3 gap-8">
      
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg overflow-hidden group hover:-translate-y-2 transition duration-300">
        <div class="h-48 bg-gray-200 dark:bg-gray-700 flex items-center justify-center">
          <img src="/Web-Dev.png" alt="Web Dev" class="h-24 object-contain" onerror="this.style.display='none'">
        </div>
        <div class="p-6 text-center">
          <h5 class="text-xl font-bold mb-2">WEB DEVELOPMENT</h5>
          <p class="text-gray-600 dark:text-gray-400 text-sm opacity-0 group-hover:opacity-100 transition duration-300">
            Expertise in <strong>HTML</strong>, <strong>CSS</strong>, <strong>JavaScript</strong>, <strong>React.js</strong> and <strong>Python</strong>.
          </p>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg overflow-hidden group hover:-translate-y-2 transition duration-300">
        <div class="h-48 bg-gray-200 dark:bg-gray-700 flex items-center justify-center">
          <img src="/sql-unix.png" alt="SQL" class="h-24 object-contain" onerror="this.style.display='none'">
        </div>
        <div class="p-6 text-center">
          <h5 class="text-xl font-bold mb-2">ORACLE AND UNIX</h5>
          <p class="text-gray-600 dark:text-gray-400 text-sm opacity-0 group-hover:opacity-100 transition duration-300">
            Experienced in <strong>Oracle Apps</strong> and <strong>PL/SQL</strong>. Automated tasks using <strong>Bash Scripting</strong>.
          </p>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg overflow-hidden group hover:-translate-y-2 transition duration-300">
        <div class="h-48 bg-gray-200 dark:bg-gray-700 flex items-center justify-center">
          <img src="/Cloud.png" alt="Cloud" class="h-24 object-contain" onerror="this.style.display='none'">
        </div>
        <div class="p-6 text-center">
          <h5 class="text-xl font-bold mb-2">CLOUD</h5>
          <p class="text-gray-600 dark:text-gray-400 text-sm opacity-0 group-hover:opacity-100 transition duration-300">
            Certified in <strong>Azure</strong> and <strong>Google Cloud Platform (GCP)</strong>.
          </p>
        </div>
      </div>

    </div>
  </section>
</main>

<%- include('partials/footer') %>